#cloud-config
users:
  - name: packer
    plain_text_passwd: packer
    lock_passwd: false
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys: []

# Enable password auth for Packer SSH
ssh_pwauth: true

# Grow the root partition to fill the disk
growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

# Ensure cloud-init does not interfere with network on first boot
network:
  config: disabled
